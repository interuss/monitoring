              </MultiGeometry>
            </Placemark>
          </Folder>
        </Folder>
      </Folder>
      <Folder>
        <name/>
        <Folder>
          <name>Cleanup</name>
        </Folder>
      </Folder>
    </Folder>
  </Document>
</kml>
